# Порт сервера (по умолчанию 3000)
PORT=3000
# Хост (0.0.0.0 — доступ с других машин)
HOST=0.0.0.0
# Путь к файлу SQLite (по умолчанию ./data/chagourtee.db)
# CHAGOURTEE_DB_PATH=./data/chagourtee.db
# Секрет для подписи cookie (обязательно смените в продакшене)
CHAGOURTEE_SESSION_SECRET=change-me-in-production
# Секрет для создания первого владельца: при первой регистрации передайте bootstrap с этим значением
# CHAGOURTEE_BOOTSTRAP_SECRET=your-secret
# Максимальный размер файла для загрузки:
# 0 = отключить загрузку, -1 = без ограничений, >0 = лимит в байтах
CHAGOURTEE_MAX_FILE_SIZE=52428800
# Общая квота медиа-хранилища:
# -1 = без ограничений, >=0 = лимит в байтах
CHAGOURTEE_MAX_STORAGE_SIZE=-1
# Политика при превышении общей квоты:
# block | delete_oldest
CHAGOURTEE_STORAGE_CLEANUP_STRATEGY=block
# Резервные значения для автоочистки orphaned-файлов
CHAGOURTEE_ORPHAN_MEDIA_CLEANUP_ENABLED=true
CHAGOURTEE_ORPHAN_MEDIA_CLEANUP_INTERVAL_MINUTES=60
CHAGOURTEE_ORPHAN_MEDIA_CLEANUP_GRACE_MINUTES=10
# Ключ шифрования для медиафайлов (должен быть 32 байта для AES-256)
CHAGOURTEE_MEDIA_ENCRYPTION_KEY=32_byte_long_key_for_aes_256_gcm
# Публичный URL для отображения в интерфейсе
# VITE_APP_PUBLIC_URL=http://<YOUR_IP_ADRESS>:5173/
# Debug mode
VITE_DEBUG_MODE=false

# Logging configuration
# Enable logging to file (chagourtee.log)
CHAGOURTEE_LOG_TO_FILE=false
# Log level: error, warn, info, debug, trace
CHAGOURTEE_LOG_LEVEL=info
# Custom log directory (optional, defaults to server/logs/)
# CHAGOURTEE_LOG_DIR=/path/to/custom/logs