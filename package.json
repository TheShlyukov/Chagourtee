{
  "name": "chagourtee",
  "version": "pre-v0.4.0-alpha",
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm run build --workspace=@chagourtee/client",
    "build:server": "cd server && npm run build",
    "start": "node scripts/start.js",
    "start:server": "cd server && npm run start:prod",
    "start:client": "cd client && npm run preview",
    "update": "cd server && npm run update-service",
    "db:backup": "cd server && npm run db:backup",
    "db:update-schema": "cd server && npm run db:update-schema",
    "db:add-media-table": "cd server && npm run db:add-media-table",
    "generate-encryption-key": "cd server && npm run generate-encryption-key"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}