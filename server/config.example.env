# Порт сервера (по умолчанию 3000)
PORT=3000
# Хост (0.0.0.0 — доступ с других машин)
HOST=0.0.0.0
# Путь к файлу SQLite (по умолчанию ./data/chagourtee.db)
# CHAGOURTEE_DB_PATH=./data/chagourtee.db
# Секрет для подписи cookie (обязательно смените в продакшене)
CHAGOURTEE_SESSION_SECRET=change-me-in-production
# Секрет для создания первого владельца: при первой регистрации передайте bootstrap с этим значением
# CHAGOURTEE_BOOTSTRAP_SECRET=your-secret
# Максимальный размер файла для загрузки (по умолчанию 50MB в байтах)
CHAGOURTEE_MAX_FILE_SIZE=52428800
# Ключ шифрования для медиафайлов (должен быть 32 байта для AES-256)
CHAGOURTEE_MEDIA_ENCRYPTION_KEY=32_byte_long_key_for_aes_256_gcm
# Maximum file size for upload (default 50MB in bytes)
CHAGOURTEE_MAX_FILE_SIZE=524288000
# Публичный URL для отображения в интерфейсе
# VITE_APP_PUBLIC_URL=http://<YOUR_IP_ADRESS>:5173/
# Debug mode
VITE_DEBUG_MODE=false